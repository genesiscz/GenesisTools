# SQLite database file. ABSOLUTE path required in production (a relative path
# resolves against the PM2 cwd and silently opens a different/empty DB).
SQLITE_PATH=/opt/dashboard/data/dashboard.sqlite

# Drizzle migrations folder. ABSOLUTE path in production (kept with the source
# tree on the deploy host). Dev auto-resolves relative to drizzle/index.ts.
MIGRATIONS_DIR=/opt/dashboard/src/dashboard/apps/web/src/drizzle/migrations

# WorkOS AuthKit — REQUIRED. Sign-in is broken if any of these is missing;
# the server fails fast at startup (validated in src/lib/env.ts).
WORKOS_API_KEY=sk_...
WORKOS_CLIENT_ID=client_...
WORKOS_REDIRECT_URI=https://your.domain/auth/callback
WORKOS_COOKIE_PASSWORD=replace-with-at-least-32-random-characters

# AI chat — optional. If absent, /api/ai-chat returns HTTP 503.
ANTHROPIC_API_KEY=sk-ant-...

# Nitro listens on NITRO_PORT ?? PORT. The PM2 ecosystem sets PORT=3000;
# set here only if running bare `node .output/server/index.mjs`.
PORT=3000

# MCP endpoint auth — OPTIONAL. Both must be set to enable /mcp; if either is
# absent /mcp returns HTTP 501. MCP_BEARER_TOKEN must be >= 16 chars.
# MCP_BEARER_TOKEN=
# MCP_USER_ID=

NODE_ENV=production
