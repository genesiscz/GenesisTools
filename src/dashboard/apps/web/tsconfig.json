{
  "include": ["**/*.ts", "**/*.tsx"],
  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["vite/client"],

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "noEmit": true,

    /* Linting */
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,
    "paths": {
      "@/*": ["./src/*"],
      "@ui": ["../../../utils/ui/index.ts"],
      "@ui/*": ["../../../utils/ui/*"],
      "@genesiscz/utils/logger/client": ["../../../utils/logger/client.ts"],
      "@genesiscz/utils/json": ["../../../utils/json.ts"],
      "@genesiscz/utils/env.client": ["../../../utils/env.client.ts"],
      "@genesiscz/utils/env": ["../../../utils/env/index.ts"],
      "@genesiscz/utils/env/*": ["../../../utils/env/*"],
      "@dashboard/shared": ["../../packages/shared/src/index.ts"],
      "@dashboard/shared/*": ["../../packages/shared/src/*"]
    }
  }
}
