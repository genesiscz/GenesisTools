{
    "name": "@genesiscz/utils",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "description": "GenesisTools pure utils surface for external consumption. Full GT tree remains under the @genesiscz/tools root; this package only exports modules without @app/* aliases.",
    "exports": {
        ".": {
            "bun": "./index.ts",
            "types": "./index.ts",
            "default": "./index.ts"
        },
        "./json": {
            "bun": "./json.ts",
            "types": "./json.ts",
            "default": "./json.ts"
        },
        "./date": {
            "bun": "./date.ts",
            "types": "./date.ts",
            "default": "./date.ts"
        },
        "./date-locale": {
            "bun": "./date-locale.ts",
            "types": "./date-locale.ts",
            "default": "./date-locale.ts"
        },
        "./format": {
            "bun": "./format.ts",
            "types": "./format.ts",
            "default": "./format.ts"
        },
        "./string": {
            "bun": "./string.ts",
            "types": "./string.ts",
            "default": "./string.ts"
        },
        "./array": {
            "bun": "./array.ts",
            "types": "./array.ts",
            "default": "./array.ts"
        },
        "./object": {
            "bun": "./object.ts",
            "types": "./object.ts",
            "default": "./object.ts"
        },
        "./math": {
            "bun": "./math.ts",
            "types": "./math.ts",
            "default": "./math.ts"
        },
        "./hash": {
            "bun": "./hash.ts",
            "types": "./hash.ts",
            "default": "./hash.ts"
        },
        "./tokens": {
            "bun": "./tokens.ts",
            "types": "./tokens.ts",
            "default": "./tokens.ts"
        },
        "./Stopwatch": {
            "bun": "./Stopwatch.ts",
            "types": "./Stopwatch.ts",
            "default": "./Stopwatch.ts"
        }
    },
    "dependencies": {
        "comment-json": "^4.6.2",
        "gpt-3-encoder": "^1.1.4"
    }
}
