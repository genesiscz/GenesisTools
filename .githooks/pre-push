#!/bin/sh

# Pre-push hook — mirrors CI exactly (.github/workflows/ci.yml).
# Catches issues that pre-commit's --staged mode misses, e.g. the dashboard's
# tab-indented biome.json (excluded from the root biome includes, so biome
# --staged from the root or from inside the dashboard reports "Checked 0 files"
# even when dashboard files are staged).
#
# Activate: git config core.hooksPath .githooks

set -e

# Skip if pushing nothing (e.g. delete-only push).
if ! read -r local_ref local_sha remote_ref remote_sha; then
    exit 0
fi

if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
    exit 0
fi

echo "▶ bun run lint..."
bun run lint

echo "▶ bun run lint:dashboard..."
bun run lint:dashboard

echo "▶ bun run typecheck:all..."
if ! bun run typecheck:all; then
    echo "▶ typecheck failed — running bun install and retrying..."
    bun install
    bun run typecheck:all
fi

echo "✔ pre-push passed (CI mirror)"
# Note: `bash scripts/ci/check-hardcoded-paths.sh` catches hardcoded /tmp/Users
# paths in src/. Not wired in here yet — pre-push currently fails on a batch
# of pre-existing `lint` errors (codemod test fixtures, useless catches) that
# are unrelated to the path check. Once those clear, append the hardcoded-paths
# script after the typecheck line above.
