{
  "name": "@devdashboard/cloud-web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 7251 --host ${DD_CLOUD_BIND_HOST:-127.0.0.1}",
    "build": "vite build",
    "preview": "node .output/server/index.mjs",
    "start": "node .output/server/index.mjs",
    "test": "bun test ../shared && vitest run",
    "test:shared": "bun test ../shared",
    "test:node": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check-types": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.0.6",
    "@tanstack/react-query": "^5.66.5",
    "@tanstack/react-router": "^1.168.0",
    "@tanstack/react-router-ssr-query": "^1.167.0",
    "@tanstack/react-start": "^1.168.0",
    "@tanstack/router-plugin": "^1.168.0",
    "better-auth": "^1.2.7",
    "better-sqlite3": "^12.6.0",
    "drizzle-orm": "^0.45.1",
    "h3": "^2.0.1-rc.7",
    "lucide-react": "^0.562.0",
    "nitro": "latest",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "stripe": "^18.5.0",
    "tailwindcss": "^4.0.6",
    "vite-tsconfig-paths": "^6.0.2",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.4",
    "@playwright/test": "^1.60.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.8",
    "typescript": "^5.7.2",
    "vite": "^8.0.13",
    "vitest": "^3.0.5"
  }
}
