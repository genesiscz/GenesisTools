# DevDashboard Cloud — environment template.
# Copy to `.env` and fill in. NEVER commit a real `.env` (it is gitignored).
# Every value here is read in server/lib/env.ts. Stripe + Cloudflare are OPTIONAL:
# without them the server still boots and landing/auth/dashboard work credential-less;
# the corresponding features return a graceful "not configured" response.

# ── Core (safe defaults provided in code) ───────────────────────────────────
NODE_ENV=development
# Public base URL of this app (used for auth callbacks + Stripe redirect URLs).
DD_CLOUD_APP_URL=http://localhost:7251
# Apex managed domain offered to managed-tier users.
DD_CLOUD_MANAGED_DOMAIN=devdashboard.app

# ── Database (SQLite now; Postgres-ready) ────────────────────────────────────
# SQLite file path (relative resolves from DevDashboard/cloud/web/).
DD_CLOUD_DATABASE_URL=./data/cloud.db
# Set to "postgres" to swap the driver (then DD_CLOUD_DATABASE_URL is the PG connection string).
DD_CLOUD_DATABASE_DRIVER=sqlite

# ── Auth (Better-Auth) ───────────────────────────────────────────────────────
# Secret used to sign sessions. REQUIRED in production (a dev-only fallback is used when unset).
# Generate with: openssl rand -base64 32
DD_CLOUD_AUTH_SECRET=

# ── Stripe (OPTIONAL — billing is inert without these) ───────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_TEAM_MONTHLY=

# ── Cloudflare for SaaS (OPTIONAL — managed-subdomain provisioning is inert without these) ──
# An API token scoped to the managed zone with "SSL and Certificates: Edit" + "DNS: Edit".
CLOUDFLARE_API_TOKEN=
# The zone id of the managed apex domain (DD_CLOUD_MANAGED_DOMAIN).
CLOUDFLARE_ZONE_ID=
# CNAME target that managed custom hostnames point at (the SaaS fallback origin).
CLOUDFLARE_FALLBACK_ORIGIN=fallback.devdashboard.app

# ── Server bind host (optional) ──────────────────────────────────────────────
# 127.0.0.1 (default) for localhost-only; 0.0.0.0 to expose on LAN / behind a tunnel.
DD_CLOUD_BIND_HOST=127.0.0.1
