{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/assets/*": [
        "./assets/*"
      ],
      "@dd/*": [
        "../../src/dev-dashboard/*"
      ],
      "@app/utils/json": [
        "./src/shims/safe-json.ts"
      ],
      "@app/*": [
        "../../src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "e2e"
  ]
}